{
  "name": "yumeangelica.github.io",
  "version": "2.1.2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "author": "yumeangelica",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pr-description": "bun run scripts/pr-description.js",
    "patch-push": "bun run scripts/release-push.js patch",
    "minor-push": "bun run scripts/release-push.js minor",
    "major-push": "bun run scripts/release-push.js major",
    "deploy": "bun run build && bun run scripts/deploy-gh-pages.js"
  },
  "dependencies": {
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.1",
    "terser": "^5.46.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
